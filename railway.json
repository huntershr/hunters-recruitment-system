{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "gunicorn -w 2 -k uvicorn.workers.UvicornWorker app.main:app --bind 0.0.0.0:$PORT --timeout 120",
    "preDeploy": "python migrate_db.py",
    "restartPolicyCondition": "on-failure",
    "restartPolicyMaxRetries": 5
  }
}
