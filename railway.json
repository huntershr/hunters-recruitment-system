{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c 'python create_sample_jobs.py && uvicorn app.main:app --host 0.0.0.0 --port $PORT'",
    "restartPolicyCondition": "on-failure",
    "restartPolicyMaxRetries": 5
  }
}


