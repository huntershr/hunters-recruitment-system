# DATABASE_URL=postgresql://admin:password@localhost:5432/recruitment
# Fallback to SQLite if not using docker
# DATABASE_URL=sqlite:///./recruitment.db

# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Sheets Integration (Via Apps Script Web App)
# Get from your deployed Google Apps Script webhook
GOOGLE_APPS_SCRIPT_URL=your_google_apps_script_url_here
